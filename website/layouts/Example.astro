---
import { withBase } from "../utils/url";
import packageJson from "../../package.json";

interface Props {
  source: string;
  title?: string;
}

const { source, title = "Example" } = Astro.props;
const isProd = import.meta.env.PROD;

const datGuiVersion = packageJson.dependencies["dat.gui"].replace(/^[^\d]*/, "");
const statsVersion = packageJson.dependencies["stats.js"].replace(/^[^\d]*/, "");
const datGuiUrl = isProd
  ? `https://cdn.jsdelivr.net/npm/dat.gui@${datGuiVersion}/build/dat.gui.module.js`
  : "/node_modules/dat.gui/build/dat.gui.module.js";
const statsUrl = isProd
  ? `https://cdn.jsdelivr.net/npm/stats.js@${statsVersion}/src/Stats.js`
  : "/node_modules/stats.js/src/Stats.js";

const importMap = JSON.stringify({
  imports: {
    webgllis: isProd ? withBase("/vendor/webgllis/index.module.js") : "/src/index.js",
    "dat.gui": datGuiUrl,
    "stats.js": statsUrl,
  },
});

const rewriteAssetLiterals = (script: string): string =>
  script.replace(/(["'`])\/?assets\/([^"'`]+)\1/g, (_, _quote: string, rest: string) => {
    return '`' + withBase(`/${rest}`) + '`';
  });
const runnerScript = isProd? rewriteAssetLiterals(source) : source

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        background: #ffffff;
        overflow: hidden;
      }

      canvas {
        background-color: black;
        touch-action: none;
      }
      .performance-monitor {
        position: fixed;
        top: 0%;
        right: 0%;
        cursor: pointer;
        opacity: 0.9;
        z-index: 10000;
      }
    </style>
    <script type="importmap" set:html={importMap} />
  </head>
  <body>
    <script type="module" set:html={runnerScript} />
  </body>
</html>
