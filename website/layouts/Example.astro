---
interface Props {
  source: string;
  title?: string;
}

const { source, title = "Example" } = Astro.props;
const importMap = JSON.stringify({
  imports: {
    webgllis: "/src/index.js",
    "dat.gui": "/node_modules/dat.gui/build/dat.gui.module.js",
    "stats.js": "/node_modules/stats.js/src/Stats.js",
  },
});
const runnerScript = `import Stats from "stats.js";
window.Stats = Stats;

${source}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        background: #ffffff;
        overflow: hidden;
      }

      canvas {
        background-color: black;
      }
      .performance-monitor {
        position: fixed;
        top: 0%;
        right: 0%;
        cursor: pointer;
        opacity: 0.9;
        z-index: 10000;
      }
    </style>
    <script type="importmap" set:html={importMap} />
  </head>
  <body>
    <script type="module" set:html={runnerScript} />
  </body>
</html>
